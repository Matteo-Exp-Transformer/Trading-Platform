# ─────────────────────────────────────────────────────────────────────────────
# FREEDOM TRADING SYSTEM — modello di configurazione
# Copia in `.env` e riempi i valori reali. NON committare mai `.env`.
# Tutti questi valori vivono SOLO lato server: mai esporli al client.
# (Provvisorio — i nomi finali si confermano alla milestone M0.)
# ─────────────────────────────────────────────────────────────────────────────

# --- AI provider (switcher) ---
AI_PROVIDER=google
# Modello con vista; default sul più capace (qualità prima). Esempi da confermare nel test vista.
AI_MODEL=gemini-2.5-pro
GOOGLE_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=            # usato dal client per Auth (chiave pubblica)
SUPABASE_SERVICE_ROLE_KEY=    # SOLO server — accesso privilegiato, mai nel client

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Freno anti-runaway (controllo costi, valori da definire) ---
MAX_ANALISI_PER_SESSIONE=
MAX_SCREENSHOT_PER_ANALISI=
