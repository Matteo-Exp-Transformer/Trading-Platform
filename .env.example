# ─────────────────────────────────────────────────────────────────────────────
# FREEDOM TRADING SYSTEM — modello di configurazione
# Copia in `.env.local` e riempi i valori reali. NON committare mai `.env.local`.
# Le variabili senza prefisso VITE_ sono server-only. Le due VITE_SUPABASE_* sono pubbliche
# per design e finiscono nel bundle; la sicurezza dipende da RLS e privilegi.
# ─────────────────────────────────────────────────────────────────────────────

# --- AI provider (switcher) ---
# Provider della catena agente. In M3 è implementato "google" (Gemini, modello con vista).
AI_PROVIDER=google
# Modello con vista; Flash 2.5 è il default validato per qualità/costo. Letto da .env.
AI_MODEL=gemini-2.5-flash
# Chiave Google AI (Gemini). SOLO server, mai nel client/bundle. (LOCK segreti.)
GOOGLE_API_KEY=
# Classificatore di sicurezza (server-only). Default codice: gemini-2.5-flash.
TOPIC_GUARD_MODEL=gemini-2.5-flash

# --- Supabase (server + test) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=            # chiave pubblica (anon/publishable) — usata anche dal client
SUPABASE_SERVICE_ROLE_KEY=    # SOLO server — accesso privilegiato, mai nel client

# --- Supabase (client Vite) ---
# Stesse credenziali della sezione sopra, prefisso VITE_ per esporle al bundle React.
# La anon-key è pubblica per design: la sicurezza è garantita dalla RLS, non dal segreto della chiave.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Account demo per test (login UI manuale / agenti) ---
# Account creato a mano dal pannello Supabase con "Auto Confirm". Niente registrazione aperta.
# I valori reali vivono SOLO in .env.local (gitignored), mai in un file tracciato.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Limite screenshot (finestra di contesto, NON costi) ---
# Nessun freno costi in demo (vedi CONTESTO_PRODOTTO L12). Resta solo il limite immagini
# per non saturare la finestra di contesto del modello. La route usa 3 se vuoto
# (vedi CHAT_ANALISI_CONTEXT §4).
MAX_SCREENSHOT_PER_ANALISI=

# --- Limite conversazione ---
# Prima analisi esclusa; default codice 5. Non è una quota commerciale.
MAX_FOLLOW_UP_PER_SESSIONE=5

# --- Rate limit analisi (anti-abuso costi AI) ---
# Richieste di analisi per minuto per sessione (prima analisi + follow-up). Default codice 6.
MAX_ANALISI_PER_MINUTO=6
